rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * APEX LEDGER SECURITY RULES - PROTOTYPE MODE
     *
     * In this prototype version, we've simplified the rules to ensure that
     * any authenticated user can read and write data. This bypasses the complex
     * 'members' map check to allow for immediate functional testing.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** 
     * @description Simplified for Prototype. 
     * Allows access if signed in. In production, this would check a membership map.
     */
    function isCompanyMember(companyId) {
      return isSignedIn();
    }

    function canWriteToCompany(companyId) {
      return isSignedIn();
    }

    function isLinkedToPath(field, pathId) {
      return request.resource.data[field] == pathId;
    }

    // --- Collection Rules ---

    match /userProfiles/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; 
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    match /chartOfAccountTypes/{id} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /companies/{companyId} {
      allow read, create, update: if isSignedIn();
      allow delete: if false;
      
      // All subcollections under a company
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn();
      }
    }
  }
}