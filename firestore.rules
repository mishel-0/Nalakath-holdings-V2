rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * APEX LEDGER SECURITY RULES - PROTOTYPE MODE
     *
     * In this prototype version, we allow any authenticated user to read and write
     * to any document in the database. This ensures that development is not blocked
     * by permission errors while the data structure is evolving.
     */

    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}