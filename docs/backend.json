
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Stores user data and roles.",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["Admin", "Accountant", "Developer"] }
      },
      "required": ["id", "firstName", "lastName", "email", "role"]
    },
    "AuditLog": {
      "title": "AuditLog",
      "type": "object",
      "description": "System-wide log for tracking creates, edits, and deletions.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "action": { "type": "string" },
        "entity": { "type": "string" },
        "entityId": { "type": "string" },
        "details": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "action", "entity", "timestamp"]
    },
    "SystemError": {
      "title": "SystemError",
      "type": "object",
      "description": "Tracks all system-level exceptions and errors.",
      "properties": {
        "id": { "type": "string" },
        "message": { "type": "string" },
        "source": { "type": "string" },
        "severity": { "type": "string", "enum": ["warning", "critical"] },
        "userId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["message", "source", "severity", "timestamp"]
    },
    "DataHealthMetric": {
      "title": "DataHealthMetric",
      "type": "object",
      "description": "Periodic snapshot of data quality metrics.",
      "properties": {
        "id": { "type": "string" },
        "score": { "type": "number" },
        "invalidCount": { "type": "number" },
        "missingFieldsCount": { "type": "number" },
        "duplicateCount": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/userProfiles/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "Global user profiles."
    },
    "/auditLogs/{logId}": {
      "schema": { "$ref": "#/backend/entities/AuditLog" },
      "description": "Stores all system activity logs."
    },
    "/systemErrors/{errorId}": {
      "schema": { "$ref": "#/backend/entities/SystemError" },
      "description": "Central repository for error logs."
    },
    "/dataHealthMetrics/{metricId}": {
      "schema": { "$ref": "#/backend/entities/DataHealthMetric" },
      "description": "Data quality snapshots."
    }
  }
}
