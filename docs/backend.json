
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Stores user data and roles.",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string" }
      },
      "required": ["id", "firstName", "lastName", "email", "role"]
    },
    "AuditLog": {
      "title": "AuditLog",
      "type": "object",
      "description": "System-wide log for tracking creates, edits, and deletions.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "action": { "type": "string" },
        "entity": { "type": "string" },
        "entityId": { "type": "string" },
        "details": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "action", "entity", "timestamp"]
    },
    "JournalEntry": {
      "title": "JournalEntry",
      "type": "object",
      "description": "Financial transaction records.",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "description": { "type": "string" },
        "totalDebit": { "type": "number" },
        "totalCredit": { "type": "number" }
      }
    },
    "Expense": {
      "title": "Expense",
      "type": "object",
      "description": "Company spending records.",
      "properties": {
        "id": { "type": "string" },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "expenseCategory": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/auditLogs/{logId}": {
      "schema": { "$ref": "#/backend/entities/AuditLog" },
      "description": "Stores all system activity logs."
    },
    "/companies/{companyId}/journalEntries/{entryId}": {
      "schema": { "$ref": "#/backend/entities/JournalEntry" },
      "description": "Company journal entries."
    }
  }
}
