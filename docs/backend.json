
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Stores user data and roles.",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["Admin", "Accountant", "Developer"] }
      },
      "required": ["id", "firstName", "lastName", "email", "role"]
    },
    "TaxRecord": {
      "title": "TaxRecord",
      "type": "object",
      "description": "Individual tax calculation records for transactions.",
      "properties": {
        "id": { "type": "string" },
        "transactionId": { "type": "string" },
        "baseAmount": { "type": "number" },
        "taxRate": { "type": "number" },
        "cgst": { "type": "number" },
        "sgst": { "type": "number" },
        "igst": { "type": "number" },
        "otherTaxes": { "type": "array", "items": { "type": "object" } },
        "totalTax": { "type": "number" },
        "finalAmount": { "type": "number" },
        "type": { "type": "string", "enum": ["Input", "Output"] },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "TaxPreset": {
      "title": "TaxPreset",
      "type": "object",
      "description": "Saved tax configurations.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "config": { "type": "object" },
        "createdBy": { "type": "string" }
      }
    },
    "TaxRule": {
      "title": "TaxRule",
      "type": "object",
      "description": "Dynamic tax logic rules.",
      "properties": {
        "id": { "type": "string" },
        "condition": { "type": "string" },
        "action": { "type": "string" },
        "isActive": { "type": "boolean" }
      }
    },
    "AuditLog": {
      "title": "AuditLog",
      "type": "object",
      "description": "System-wide log for tracking creates, edits, and deletions.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "action": { "type": "string" },
        "entity": { "type": "string" },
        "entityId": { "type": "string" },
        "details": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "action", "entity", "timestamp"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/userProfiles/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "Global user profiles."
    },
    "/taxRecords/{recordId}": {
      "schema": { "$ref": "#/backend/entities/TaxRecord" },
      "description": "Detailed tax calculation history."
    },
    "/taxPresets/{presetId}": {
      "schema": { "$ref": "#/backend/entities/TaxPreset" },
      "description": "Saved tax configurations."
    },
    "/taxRules/{ruleId}": {
      "schema": { "$ref": "#/backend/entities/TaxRule" },
      "description": "Dynamic tax calculation logic."
    },
    "/auditLogs/{logId}": {
      "schema": { "$ref": "#/backend/entities/AuditLog" },
      "description": "Stores all system activity logs."
    }
  }
}
